{
  "$schema": "https://schemas.tauri.app/config/v2/capability.json",
  "identifier": "default",
  "description": "TrackCast default capabilities",
  "platforms": ["macOS"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:scope-home-recursive",
    "fs:scope-applocaldata-recursive"
  ]
}
