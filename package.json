{
  "name": "trackcast-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/mac",
    "apps/windows",
    "packages/app"
  ],
  "scripts": {
    "dev:mac": "npm --workspace @trackcast/mac run tauri -- dev",
    "vite:mac": "npm --workspace @trackcast/mac run dev",
    "build:mac": "npm --workspace @trackcast/mac run build",
    "tauri:mac": "npm --workspace @trackcast/mac run tauri",
    "tauri:mac:build": "npm --workspace @trackcast/mac run tauri -- build",
    "dev:windows": "npm --workspace @trackcast/windows run tauri -- dev",
    "vite:windows": "npm --workspace @trackcast/windows run dev",
    "build:windows": "npm --workspace @trackcast/windows run build",
    "tauri:windows": "npm --workspace @trackcast/windows run tauri",
    "tauri:windows:build": "npm --workspace @trackcast/windows run tauri -- build",
    "site": "python3 -m http.server 8787"
  }
}
